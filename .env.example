# ctxindex environment reference. Resolution order for paths is CTXINDEX_* > XDG_* > home defaults.

# Paths: override the config directory (default: $XDG_CONFIG_HOME/ctxindex or ~/.config/ctxindex).
CTXINDEX_CONFIG_HOME=

# Paths: override the data directory for SQLite, raw records, and file secrets (default: $XDG_DATA_HOME/ctxindex or ~/.local/share/ctxindex).
CTXINDEX_DATA_HOME=

# Paths: override the state directory for logs and operator state (default: $XDG_STATE_HOME/ctxindex or ~/.local/state/ctxindex).
CTXINDEX_STATE_HOME=

# Paths: override the cache directory for purgeable data (default: $XDG_CACHE_HOME/ctxindex or ~/.cache/ctxindex).
CTXINDEX_CACHE_HOME=

# Log: set trace, debug, info, warn, error, or fatal (default: info).
CTXINDEX_LOG_LEVEL=info

# Log: set to 1 for synchronous log writes in tests or crash debugging; no default.
CTXINDEX_LOG_SYNC=

# Log test: canary value that must be redacted from log output; no default.
CTXINDEX_LOG_CANARY_TOKEN=

# Secrets: only for opening a passphrase-mode file envelope; fresh file storage uses a private secret.key.
CTXINDEX_SECRETS_PASSPHRASE=

# Secrets: file-backed keytar mock store for tests; no default.
CTXINDEX_KEYTAR_MOCK_FILE=

# Browser/OAuth: set to 1 in headless test runs to print the loopback auth URL instead of launching a browser; no default.
CTXINDEX_NO_BROWSER=

# Browser/OAuth: loopback listener timeout in seconds (default: 300).
CTXINDEX_LOOPBACK_TIMEOUT_SECS=

# Browser/OAuth test: provider-neutral loopback mock base for /oauth/<provider>/{authorize,token,identity}; ignored in production.
CTXINDEX_OAUTH_MOCK_BASE_URL=

# Google OAuth client input: read only by `client add google --from-env`, then persisted through the configured secrets backend.
CTXINDEX_GOOGLE_CLIENT_ID=

# Google OAuth client input: optional confidential client secret read only by `client add google --from-env`; never pass literal secret values on argv.
CTXINDEX_GOOGLE_CLIENT_SECRET=

# Microsoft OAuth client input: read only by `client add microsoft --from-env`, then persisted through the configured secrets backend.
CTXINDEX_MICROSOFT_CLIENT_ID=

# Microsoft Graph test: loopback-only API mock base; ignored in production.
CTXINDEX_GRAPH_MOCK_BASE_URL=

# Gmail test: override the Gmail API base URL for local mocks; ignored by the production allowlist; no default.
CTXINDEX_GMAIL_MOCK_BASE_URL=

# Test/development: loopback-only Google Calendar API mock base URL; ignored in production.
CTXINDEX_GOOGLE_CALENDAR_MOCK_BASE_URL=

# Test/development: set to 1 to skip the slow turbo dry-json parse check; no default.
CTXINDEX_SKIP_TURBO_DRY_JSON=

# Test/development: force pino-roll size rotation below this many bytes when NODE_ENV is not production; no default.
CTXINDEX_TEST_LOG_ROTATE_BYTES=

# Test/development: add this many bytes of redacted debug padding to sync logs when NODE_ENV is not production; no default.
CTXINDEX_TEST_LOG_SPAM_BYTES=

# Test/development: delay local.directory sync by this many milliseconds when NODE_ENV is not production; no default.
CTXINDEX_TEST_SYNC_DELAY_MS=
