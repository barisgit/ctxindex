{
  "name": "@ctxindex/demo-tenders",
  "version": "0.1.0",
  "description": "Deterministic providerless tender data for trying ctxindex without accounts or secrets",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/barisgit/ctxindex.git",
    "directory": "examples/tenders-extension"
  },
  "keywords": [
    "ctxindex",
    "extension",
    "demo",
    "synthetic-data"
  ],
  "files": [
    "demo-extension.js",
    "docs",
    "README.md",
    "expected-output.md",
    "LICENSE"
  ],
  "ctxindex": {
    "extensions": [
      "./demo-extension.js"
    ]
  },
  "scripts": {
    "build": "bun build extension.ts --outfile demo-extension.js --target=bun --minify",
    "test": "NODE_ENV=test CTXINDEX_KEYTAR_MOCK_FILE=.turbo/keytar-unit.json bun test --path-ignore-patterns '**/*.integration.test.ts' --path-ignore-patterns '**/*.e2e.test.ts'"
  },
  "devDependencies": {
    "@ctxindex/adapters": "0.0.0",
    "@ctxindex/core": "0.0.0",
    "@ctxindex/extension-sdk": "0.0.0"
  }
}
