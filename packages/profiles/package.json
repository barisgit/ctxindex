{
  "name": "@ctxindex/profiles",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./calendar-event": "./src/calendar-event.ts",
    "./communication-message": "./src/communication-message.ts",
    "./file": "./src/file.ts"
  },
  "scripts": {
    "build": "tsgo --noEmit -p tsconfig.json",
    "lint": "biome check .",
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "test": "bun test",
    "format": "biome format --write .",
    "clean": "rm -rf .turbo dist coverage",
    "fullclean": "rm -rf .turbo dist coverage node_modules"
  },
  "dependencies": {
    "@ctxindex/extension-sdk": "workspace:*",
    "zod": "latest"
  }
}
