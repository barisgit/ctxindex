{
  "name": "@ctxindex/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./paths": "./src/paths/index.ts",
    "./config": "./src/config/index.ts",
    "./logger": "./src/logger/index.ts",
    "./artifact": "./src/artifact/index.ts",
    "./export": "./src/export/index.ts",
    "./auth": "./src/auth/index.ts",
    "./client": "./src/client/index.ts",
    "./account": "./src/account/index.ts",
    "./realm": "./src/realm/index.ts",
    "./source": "./src/source/index.ts",
    "./secrets": "./src/secrets/index.ts",
    "./secrets-service": "./src/secrets/service.ts",
    "./schema": "./src/schema/index.ts",
    "./storage": "./src/storage/index.ts",
    "./testing": "./src/testing/index.ts",
    "./net": "./src/net/index.ts",
    "./registry": "./src/registry/index.ts",
    "./extension": "./src/extension/index.ts",
    "./catalog": "./src/catalog/index.ts",
    "./sync": "./src/sync/index.ts",
    "./search": "./src/search/index.ts",
    "./thread": "./src/thread/index.ts",
    "./errors": "./src/errors.ts",
    "./ids": "./src/ids.ts",
    "./ref": "./src/ref/index.ts",
    "./migrations": "./src/migrations/index.ts",
    "./action": "./src/action/index.ts"
  },
  "scripts": {
    "build": "tsgo --noEmit -p tsconfig.json",
    "lint": "biome check .",
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "test": "bun test",
    "test:integration": "bun test --path-ignore-patterns '__none__' --pass-with-no-tests integration.test",
    "test:e2e": "bun run ../../scripts/with-timeout.ts 300 -- bun test --path-ignore-patterns '__none__' --pass-with-no-tests e2e.test",
    "format": "biome format --write .",
    "clean": "rm -rf .turbo dist coverage",
    "fullclean": "rm -rf .turbo dist coverage node_modules"
  },
  "dependencies": {
    "@ctxindex/extension-sdk": "workspace:*",
    "@iarna/toml": "latest",
    "@noble/ciphers": "latest",
    "@noble/hashes": "latest",
    "drizzle-orm": "latest",
    "keytar": "latest",
    "pino": "latest",
    "pino-pretty": "latest",
    "pino-roll": "latest",
    "ulid": "latest",
    "zod": "latest"
  }
}
