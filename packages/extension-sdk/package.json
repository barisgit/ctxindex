{
  "name": "@ctxindex/extension-sdk",
  "version": "0.1.1",
  "description": "Type-safe authoring SDK for ctxindex Extensions and Catalogs.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "bun ../../scripts/release/extension-sdk-package.ts build",
    "lint": "biome check .",
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "test": "NODE_ENV=test CTXINDEX_KEYTAR_MOCK_FILE=.turbo/keytar-unit.json bun test --path-ignore-patterns '**/*.integration.test.ts' --path-ignore-patterns '**/*.e2e.test.ts'",
    "format": "biome format --write .",
    "clean": "rm -rf .turbo dist coverage",
    "fullclean": "rm -rf .turbo dist coverage node_modules"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
