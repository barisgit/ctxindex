{
  "name": "ctxindex-root",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "bin": {
    "ctxindex": "./apps/cli/bin/ctxindex.mjs"
  },
  "scripts": {
    "build": "turbo run build",
    "lint": "biome check .",
    "typecheck": "tsgo --noEmit -p tsconfig.base.json",
    "test": "bun test",
    "ci": "bash scripts/verify/ci.sh",
    "db:generate": "turbo run db:generate"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/bun": "^1.3.14",
    "@typescript/native-preview": "^7.0.0-dev.20260519.1",
    "drizzle-kit": "^0.31.10",
    "turbo": "^2.9.14",
    "typescript": "^6.0.3"
  }
}
