{
  "name": "ctxindex-monorepo",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "dev": "turbo run dev --filter web",
    "start": "turbo run start --filter web",
    "build": "turbo run build",
    "build:web": "turbo run build --filter web",
    "build:cli": "turbo run build --filter ctxindex",
    "generate:cli-reference": "bun scripts/docs/generate-cli-reference.ts",
    "check:cli-reference": "bun scripts/docs/generate-cli-reference.ts --check",
    "pack:cli-package": "bun scripts/release/cli-package.ts pack dist/npm/artifacts",
    "smoke:cli-package": "bun scripts/release/cli-package.ts smoke",
    "build:extension-sdk-package": "bun scripts/release/extension-sdk-package.ts build",
    "pack:extension-sdk-package": "bun scripts/release/extension-sdk-package.ts pack dist/npm/artifacts",
    "verify:extension-sdk-package": "bun scripts/release/extension-sdk-package.ts verify",
    "smoke:extension-sdk-package": "bun scripts/release/extension-sdk-package.ts smoke",
    "prepare:extension-sdk-release": "bun scripts/release/extension-sdk-package.ts prepare dist/npm/artifacts",
    "lint": "turbo run lint //#verify:lint",
    "lint:staged": "lint-staged",
    "format": "turbo run format",
    "typecheck": "turbo run typecheck //#verify:typescript",
    "test": "turbo run test //#test:tooling",
    "test:integration": "turbo run test:integration //#test:integration:tooling",
    "test:e2e": "turbo run test:e2e",
    "clean": "turbo run clean && rm -rf .turbo dist build coverage && rm -f *.tsbuildinfo",
    "fullclean": "turbo run fullclean && rm -rf node_modules .turbo dist build coverage && rm -f *.tsbuildinfo",
    "verify:lint": "biome check .",
    "verify:typescript": "tsgo --noEmit -p tsconfig.base.json",
    "verify:package-dependencies": "bun scripts/verify/package-dependencies.ts",
    "verify:architecture": "bun scripts/verify/architecture-lint.ts",
    "verify:cli-no-business-logic": "bun scripts/verify/cli-no-business-logic.ts",
    "verify:cli-framework": "bun scripts/verify/cli-framework-citty.ts",
    "verify:cli-command-drift": "bun scripts/verify/cli-command-drift.ts",
    "verify:cli-thin-lines": "bun scripts/verify/cli-thin-lines.ts",
    "verify:cli-reference": "bun run check:cli-reference",
    "verify:exports-map": "bun scripts/verify/exports-map.ts",
    "verify:network-egress": "bash scripts/verify/network-egress.sh",
    "verify:no-prompts-static": "bun scripts/verify/no-prompts-static.ts",
    "test:tooling": "NODE_ENV=test CTXINDEX_KEYTAR_MOCK_FILE=.turbo/keytar-tooling-unit.json bun test --path-ignore-patterns '**/*.integration.test.ts' --path-ignore-patterns '**/*.e2e.test.ts' tests/tooling",
    "test:integration:tooling": "NODE_ENV=test CTXINDEX_KEYTAR_MOCK_FILE=.turbo/keytar-tooling-integration.json bun test --path-ignore-patterns '__none__' tests/tooling/release/cli-package.integration.test.ts tests/tooling/release/extension-sdk-package.integration.test.ts tests/tooling/verify/calendar-event-profile.integration.test.ts tests/tooling/verify/microsoft-auth.integration.test.ts",
    "ci": "turbo run build lint typecheck test //#test:tooling //#verify:lint //#verify:typescript //#verify:package-dependencies //#verify:architecture //#verify:cli-no-business-logic //#verify:cli-framework //#verify:cli-command-drift //#verify:cli-thin-lines //#verify:cli-reference //#verify:exports-map //#verify:network-egress //#verify:no-prompts-static",
    "cli": "bash scripts/cli.sh",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/bun": "^1.3.14",
    "@typescript/native-preview": "^7.0.0-dev.20260519.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "turbo": "^2.9.14",
    "typescript": "^6.0.3"
  }
}
