{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env", "**/.env.*", "**/bunfig.toml"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "dependsOn": ["build"],
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "format": {
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^test"],
      "outputs": []
    },
    "//#test:tooling": {
      "outputs": []
    },
    "//#test:integration:tooling": {
      "cache": false,
      "outputs": []
    },
    "//#verify:lint": {
      "outputs": []
    },
    "//#verify:typescript": {
      "outputs": []
    },
    "//#verify:package-dependencies": {
      "outputs": []
    },
    "//#verify:architecture": {
      "outputs": []
    },
    "//#verify:cli-no-business-logic": {
      "outputs": []
    },
    "//#verify:cli-framework": {
      "outputs": []
    },
    "//#verify:cli-command-drift": {
      "outputs": []
    },
    "//#verify:cli-thin-lines": {
      "outputs": []
    },
    "//#verify:cli-reference": {
      "outputs": []
    },
    "//#verify:exports-map": {
      "outputs": []
    },
    "test:integration": {
      "dependsOn": ["^test:integration"],
      "cache": false,
      "outputs": []
    },
    "test:e2e": {
      "dependsOn": ["^test:e2e"],
      "cache": false,
      "outputs": []
    },
    "clean": {
      "cache": false
    },
    "fullclean": {
      "cache": false
    }
  },
  "ui": "tui"
}
