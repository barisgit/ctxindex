{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env", "**/.env.*", "**/bunfig.toml"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {
      "dependsOn": ["^test"]
    },
    "test:integration": {
      "dependsOn": ["^test:integration"]
    },
    "test:e2e": {
      "dependsOn": ["^test:e2e"]
    },
    "db:generate": {
      "dependsOn": ["^db:generate"],
      "outputs": ["migrations/**"]
    }
  }
}
