{
  "name": "@ctxindex/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/main.ts"
  },
  "scripts": {
    "build": "tsgo --noEmit -p tsconfig.json",
    "lint": "biome check .",
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "test": "bun test",
    "test:integration": "bun test --path-ignore-patterns '__none__' --pass-with-no-tests integration.test",
    "test:e2e": "bun run ../../scripts/with-timeout.ts 300 -- bun test --path-ignore-patterns '__none__' --pass-with-no-tests e2e.test",
    "cli": "bash ../../scripts/cli.sh"
  },
  "dependencies": {
    "@ctxindex/adapters": "workspace:*",
    "@ctxindex/core": "workspace:*",
    "@ctxindex/extension-sdk": "workspace:*",
    "citty": "latest",
    "cli-table3": "^0.6.5",
    "zod": "latest"
  }
}
