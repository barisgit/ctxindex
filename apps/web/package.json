{
  "name": "web",
  "version": "0.0.6",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "start": "next start",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "lint": "biome check",
    "format": "biome format --write",
    "typecheck": "fumadocs-mdx && next typegen && tsc --noEmit",
    "test": "NODE_ENV=test CTXINDEX_KEYTAR_MOCK_FILE=.turbo/keytar-unit.json bun test --path-ignore-patterns '**/*.integration.test.ts' --path-ignore-patterns '**/*.e2e.test.ts'",
    "clean": "rm -rf .next .source .turbo out coverage tsconfig.tsbuildinfo",
    "fullclean": "rm -rf .next .source .turbo out coverage node_modules tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "cnfast": "^0.0.8",
    "fumadocs-core": "16.11.5",
    "fumadocs-mdx": "15.2.0",
    "fumadocs-ui": "npm:@fumadocs/base-ui@16.11.5",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/mdx": "^2.0.14",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.17",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "@biomejs/biome": "^2.5.3"
  }
}
